# Ember environment variables — TEMPLATE ONLY.
#
# Copy to `.env` at the repo root and fill in real values. `.env` is git-ignored;
# never commit real secrets. In production these live in the host's secret store.
# The API server loads this file via dotenv; Vite loads it via envDir (repo root)
# and only exposes VITE_* vars to the browser. See docs/BACKEND-SCOPE.md.

# ─── API server (artifacts/api-server) ──────────────────────────────────────
# PORT here is the API server's port. The frontend port/base path come from the
# run config (.claude/launch.json). 5000 is used by MomentumTXT, so API = 5001.
PORT=5001
NODE_ENV=development

# ─── Frontend (public — shipped in the browser bundle) ──────────────────────
# Origin only (NO /api) — the generated client already prefixes /api.
VITE_API_BASE_URL=http://localhost:5001
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ─── Clerk auth ─────────────────────────────────────────────────────────────
# Publishable key is public; the secret key is server-only. (Both come from
# the Clerk dashboard → API keys.)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ─── Database (Neon) — server-only ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ─── Later phases (server-only secrets) ─────────────────────────────────────
# Phase 3 — billing (Stripe):
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
# Phase 4 — AI reflection digest (Anthropic):
ANTHROPIC_API_KEY=sk-ant-...
