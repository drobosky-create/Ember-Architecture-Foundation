# Ember environment variables — TEMPLATE ONLY.
#
# Copy to `.env` and fill in real values. `.env` is git-ignored; never commit
# real secrets. In production these live in the host's secret store, not a file.
# See docs/BACKEND-SCOPE.md for what provisions each value.
#
# Vite only exposes variables prefixed with VITE_ to the frontend, and they are
# PUBLIC (shipped in the browser bundle) — never put a secret behind VITE_.
# For local dev, VITE_ vars must live in artifacts/ember/.env for Vite to load them.

# ─── Frontend (artifacts/ember) ─────────────────────────────────────────────
# Required today by vite.config.ts:
PORT=5173
BASE_PATH=/
# Added in later phases (public keys — safe to expose):
VITE_API_BASE_URL=http://localhost:5000/api
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ─── API server (artifacts/api-server) ──────────────────────────────────────
# PORT is also required here (defaults differ per process); NODE_ENV/LOG_LEVEL optional.
# NODE_ENV=development
# LOG_LEVEL=info

# ─── Secrets (server-only — NEVER prefix with VITE_, never commit) ───────────
# Phase 0/2 — database (Neon):
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
# Phase 1 — auth (Clerk):
CLERK_SECRET_KEY=sk_test_...
# Phase 3 — billing (Stripe):
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
# Phase 4 — AI reflection digest (Anthropic):
ANTHROPIC_API_KEY=sk-ant-...
